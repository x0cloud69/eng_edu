{
  "version": "1.0.0",
  "phase": "Phase 6 — Evolution Loop",
  "description": "프로덕션 운영 중 KPI Drift를 감지하고 Evol-A가 Context/Workflow 수정 제안을 생성하며, G-09 승인 후 회귀 테스트 및 재배포하는 지속적 개선 루프를 구축한다.",
  "depends_on": [
    "workflow_context.json",
    "hitl_context.json",
    "phase3_context.json",
    "phase4_context.json",
    "phase5_context.json",
    "saas_foundation.json",
    "governance_rules_context.json",
    "operation_standards.json",
    "system_prompt_context.json",
    "skill_context.json"
  ],

  "phase6_overview": {
    "sections": {
      "6.1": "Drift Analysis & Pattern Detection (Evol-A trajectory_logs 분석)",
      "6.2": "Context Modification Proposal (수정 제안서, 영향 범위, Risk 평가)",
      "6.3": "G-09 Approval Workflow (Governance Board P1 승인, SLA 24h)",
      "6.4": "Regression Test & Validation (Test-A 회귀 테스트, 93개 재실행)",
      "6.5": "Redeployment & Verification (승인 후 재배포, Post-Redeploy 모니터링)",
      "6.6": "Periodic Review Cycle (월 1회 정기 재검증, Evolution Report)"
    },
    "lead_agents": ["Evol-A", "Monitor-A", "Test-A", "Back-A"],
    "gate": {
      "id": "G-09",
      "name": "Context 수정 승인 Gate",
      "approver": "Governance Board",
      "hitl": "P1",
      "sla_hours": 24
    }
  },

  "evolution_agent": {
    "name": "EvolutionAgent",
    "alias": "Evol-A",
    "layer": 5,
    "authority_level": "L1",
    "risk_level": "HIGH",
    "allowed_tools": ["read_logs", "llm_call"],
    "orchestrator_pattern": "evolution.*",
    "actions": {
      "analyze_drift": {
        "risk": "MEDIUM",
        "description": "trajectory_logs 분석, 패턴 분류, 근본 원인 추론"
      },
      "propose_modification": {
        "risk": "HIGH",
        "description": "Context/Workflow 수정 제안서 생성 (G-09 승인 필요)"
      },
      "list_proposals": {
        "risk": "LOW",
        "description": "기존 수정 제안 목록 조회"
      },
      "get_proposal": {
        "risk": "LOW",
        "description": "특정 수정 제안 상세 조회"
      },
      "generate_patch_note": {
        "risk": "LOW",
        "description": "승인된 수정에 대한 패치 노트 생성"
      }
    },
    "prohibitions": [
      "Context JSON 직접 수정 (반드시 제안 → G-09 → 승인 → 반영)",
      "Agent 코드 직접 수정",
      "Rule .mdc 직접 수정",
      "재배포 직접 트리거 (Back-A 경유 필수)",
      "Approval Gate 우회",
      "테스트 없는 수정 반영"
    ]
  },

  "evolution_triggers": {
    "automatic_drift": {
      "condition": "KPI RED (variance > 20%)",
      "source": "Monitor-A → trajectory_logs",
      "flow": "Orch → Evol-A.analyze_drift → propose_modification"
    },
    "automatic_failure": {
      "condition": "동일 Agent 3회 연속 failure",
      "source": "trajectory_logs.failure_tagged = true",
      "flow": "Orch → Evol-A.analyze_drift"
    },
    "manual_request": {
      "condition": "PM/Architect 개선 요청",
      "source": "review_requests",
      "flow": "Evol-A.analyze_drift 직접 호출"
    },
    "scheduled_review": {
      "condition": "월 1회 정기 재검증",
      "source": "크론 스케줄",
      "flow": "전체 KPI + 모델 재검증"
    }
  },

  "drift_patterns": {
    "P-DRIFT": {
      "name": "KPI Drift",
      "description": "특정 KPI가 목표 대비 20% 이상 하락",
      "severity": "HIGH",
      "typical_action": "해당 KPI 관련 Context 임계값 조정 또는 Agent 로직 수정 제안"
    },
    "P-FAIL-REPEAT": {
      "name": "반복 실패",
      "description": "동일 Agent/Action 3회 이상 연속 실패",
      "severity": "HIGH",
      "typical_action": "실패 원인 분석 → Agent 로직 또는 의존성 수정 제안"
    },
    "P-LATENCY": {
      "name": "응답 시간 초과",
      "description": "Agent 평균 응답시간 SLA 초과 (e.g., > 3s)",
      "severity": "MEDIUM",
      "typical_action": "쿼리 최적화 또는 캐시 전략 수정 제안"
    },
    "P-GATE-BLOCK": {
      "name": "Gate 병목",
      "description": "승인 대기 SLA 초과 빈도 50% 이상",
      "severity": "MEDIUM",
      "typical_action": "Authority Level 조정 또는 Auto-Approve 조건 추가 제안"
    },
    "P-SCOPE-EXCEED": {
      "name": "Scope 초과",
      "description": "Agent가 허용 범위 외 Tool 사용 시도 반복",
      "severity": "HIGH",
      "typical_action": "allowed_tools 또는 scope 경계 재정의 제안"
    },
    "P-TENANT-LEAK": {
      "name": "테넌트 격리 위반",
      "description": "Multi-Tenant 격리 위반 탐지",
      "severity": "CRITICAL",
      "typical_action": "즉시 EMERGENCY Alert + 격리 강화 제안"
    }
  },

  "proposal_schema": {
    "table": "evolution_proposals",
    "columns": [
      "id UUID PK DEFAULT gen_random_uuid()",
      "tenant_id UUID NOT NULL",
      "proposal_code VARCHAR(20) NOT NULL",
      "title VARCHAR(200) NOT NULL",
      "description TEXT NOT NULL",
      "trigger_type VARCHAR(20) NOT NULL",
      "trigger_source TEXT",
      "pattern_code VARCHAR(20)",
      "affected_contexts TEXT[]",
      "affected_agents TEXT[]",
      "affected_rules TEXT[]",
      "risk_level VARCHAR(10) NOT NULL DEFAULT 'HIGH'",
      "impact_analysis JSONB",
      "proposed_changes JSONB NOT NULL",
      "rollback_plan TEXT",
      "status VARCHAR(20) NOT NULL DEFAULT 'DRAFT'",
      "gate_id VARCHAR(10) DEFAULT 'G-09'",
      "approved_by UUID",
      "approved_at TIMESTAMPTZ",
      "rejected_reason TEXT",
      "regression_test_id UUID",
      "regression_passed BOOLEAN",
      "deployed_at TIMESTAMPTZ",
      "created_at TIMESTAMPTZ DEFAULT NOW()",
      "created_by UUID",
      "updated_at TIMESTAMPTZ DEFAULT NOW()",
      "updated_by UUID"
    ],
    "indexes": [
      "idx_evo_proposal_tenant (tenant_id, status)",
      "idx_evo_proposal_pattern (pattern_code)",
      "idx_evo_proposal_status (status) WHERE status IN ('DRAFT', 'PENDING_APPROVAL', 'APPROVED')"
    ],
    "status_lifecycle": [
      "DRAFT → PENDING_APPROVAL → APPROVED → REGRESSION_TESTING → DEPLOYING → DEPLOYED",
      "DRAFT → PENDING_APPROVAL → REJECTED",
      "REGRESSION_TESTING → FAILED (회귀 테스트 실패 시)"
    ]
  },

  "evolution_log_schema": {
    "table": "evolution_logs",
    "columns": [
      "id UUID PK DEFAULT gen_random_uuid()",
      "tenant_id UUID NOT NULL",
      "proposal_id UUID REFERENCES evolution_proposals(id)",
      "action VARCHAR(50) NOT NULL",
      "actor VARCHAR(50) NOT NULL",
      "detail JSONB",
      "created_at TIMESTAMPTZ DEFAULT NOW()"
    ],
    "indexes": [
      "idx_evo_log_proposal (proposal_id)",
      "idx_evo_log_tenant (tenant_id, created_at DESC)"
    ]
  },

  "g09_gate": {
    "id": "G-09",
    "name": "Context 수정 승인 Gate",
    "phase": "Phase 6",
    "approver": "Governance Board",
    "hitl": "P1",
    "sla_hours": 24,
    "mandatory_conditions": [
      "EC-01: Drift Pattern 분석 보고서 첨부",
      "EC-02: 영향 받는 Context/Agent/Rule 목록 명시",
      "EC-03: 수정 전후 비교 (diff) 제공",
      "EC-04: Risk Level 평가 완료",
      "EC-05: 롤백 계획 수립",
      "EC-06: 회귀 테스트 시나리오 정의",
      "EC-07: 기존 93개 테스트 영향도 분석"
    ],
    "approval_workflow": {
      "submit": "Evol-A → proposal status PENDING_APPROVAL",
      "review": "Governance Board 검토 (24h SLA)",
      "approve": "status → APPROVED → Test-A 회귀 테스트 트리거",
      "reject": "status → REJECTED + rejected_reason 기록"
    }
  },

  "regression_test": {
    "scope": [
      "기존 Phase 4 테스트 93개 전체 재실행",
      "수정 대상 Agent에 대한 추가 테스트",
      "Multi-Tenant 격리 검증 재확인",
      "Approval Gate 동작 검증"
    ],
    "pass_criteria": {
      "existing_tests": "93/93 전체 Pass",
      "new_tests": "추가 테스트 100% Pass",
      "no_regression": "기존 기능 저하 없음",
      "performance": "응답시간 SLA 이내"
    },
    "on_failure": "proposal status → FAILED, Evol-A에게 수정 요청"
  },

  "periodic_review": {
    "cycle": "monthly",
    "scope": [
      "전체 KPI K-01~K-07 현황 점검",
      "지난 30일 Drift 히스토리 분석",
      "Evolution Proposal 이행 현황",
      "Agent 성능 트렌드 분석",
      "Governance 규칙 준수율 검토"
    ],
    "deliverable": "Evolution Monthly Report",
    "reviewer": "AI Architect + PM"
  },

  "phase6_deliverables": [
    "phase6_context.json — Evolution Loop Context",
    "14_evolution.mdc — Evolution 코드 생성 규칙",
    "evolution-runner Skill — Cursor Skill",
    "EvolutionAgent (agent.py, service.py, models.py, schemas.py)",
    "regression_test.sh — 회귀 테스트 스크립트",
    "Evolution Monthly Report Template",
    "Phase 6 Word Document"
  ],

  "phase6_constraints": {
    "immutable_rules": [
      "Evol-A는 절대 Context를 직접 수정할 수 없다",
      "모든 수정은 G-09 승인 후에만 반영",
      "회귀 테스트 미통과 시 절대 배포 불가",
      "P-TENANT-LEAK 패턴 발견 시 즉시 EMERGENCY"
    ],
    "evolution_boundary": {
      "modifiable": [
        "Context JSON 내 threshold/target 값",
        "Rule .mdc 내 조건부 규칙",
        "Agent allowed_tools 범위",
        "Authority Level 조정 (L0↔L1, G-09 필수)",
        "KPI 목표값 조정"
      ],
      "immutable": [
        "5대 원칙 (01_principles.mdc)",
        "보안 규칙 (02_security.mdc)",
        "BaseAgent 코어 인터페이스",
        "Audit Log 필수 기록 규칙",
        "Multi-Tenant 격리 구조"
      ]
    }
  }
}
