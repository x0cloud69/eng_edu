{
  "version": "1.0.0",
  "phase": "Phase 5 — Deploy & Monitoring",
  "description": "Phase 4 검증 완료 코드를 프로덕션 배포하고 KPI 모니터링 인프라를 구축한다.",
  "depends_on": [
    "workflow_context.json",
    "hitl_context.json",
    "phase3_context.json",
    "phase4_context.json",
    "saas_foundation.json",
    "governance_rules_context.json",
    "operation_standards.json"
  ],

  "phase5_overview": {
    "sections": {
      "5.1": "Container Packaging (Dockerfile, docker-compose)",
      "5.2": "Deployment Pipeline (CI/CD, Blue-Green, Rollback)",
      "5.3": "KPI Monitoring Infrastructure (Monitor-A, trajectory_logs)",
      "5.4": "Alert & Incident Response (Escalation, Override)",
      "5.5": "Release Gate G-08 (Checklist, Approval Workflow)",
      "5.6": "Post-Deployment Verification (Smoke Test, 48h Monitoring)"
    },
    "lead_agents": ["Back-A", "Monitor-A"],
    "gate": {
      "id": "G-08",
      "name": "Release Gate",
      "approver": "AI Architect + PM",
      "hitl": "P1",
      "sla_hours": 24
    }
  },

  "container_spec": {
    "services": {
      "backend": {
        "image": "framework-backend:latest",
        "port": 8000,
        "depends_on": ["postgres", "redis"],
        "healthcheck": "GET /health → 200",
        "base_image": "python:3.11-slim",
        "build_strategy": "multi-stage"
      },
      "frontend": {
        "image": "framework-frontend:latest",
        "port": 3000,
        "depends_on": ["backend"],
        "base_image": "node:20-alpine"
      },
      "postgres": {
        "image": "postgres:15-alpine",
        "port": 5432,
        "volumes": ["pgdata:/var/lib/postgresql/data"]
      },
      "redis": {
        "image": "redis:7-alpine",
        "port": 6379
      },
      "nginx": {
        "image": "nginx:alpine",
        "port": [80, 443],
        "depends_on": ["backend", "frontend"]
      }
    },
    "rules": [
      "Multi-Stage Build 필수 (빌드/런타임 분리)",
      "Non-root User 실행",
      "HEALTHCHECK 포함 (30s interval)",
      "Secret 하드코딩 금지 (.env 또는 Vault)",
      ".env.template 제공 필수"
    ]
  },

  "deployment_strategy": {
    "strategies": {
      "blue_green": {
        "use_when": "Major/Minor 릴리스",
        "description": "두 환경 교대 배포"
      },
      "rolling": {
        "use_when": "Patch 릴리스",
        "description": "점진적 교체"
      },
      "canary": {
        "use_when": "위험도 높은 변경",
        "description": "일부 트래픽 우선 전환"
      }
    },
    "rollback": {
      "auto_trigger": "Health Check 3회 연속 실패",
      "manual_trigger": "운영자 판단 (CRITICAL Alert)",
      "db_rollback": "alembic downgrade -1"
    }
  },

  "monitor_agent": {
    "name": "MonitorAgent",
    "alias": "Monitor-A",
    "layer": 4,
    "authority_level": "L0",
    "risk_level": "LOW",
    "allowed_tools": ["db_query"],
    "orchestrator_pattern": "monitor.*",
    "actions": {
      "collect_kpi": { "risk": "LOW", "description": "전체 KPI 데이터 수집" },
      "check_drift": { "risk": "LOW", "description": "Drift Level 판정" },
      "get_dashboard": { "risk": "LOW", "description": "KPI 대시보드 반환" },
      "get_history": { "risk": "LOW", "description": "KPI 이력 조회" },
      "get_alerts": { "risk": "LOW", "description": "활성 Alert 목록 조회" }
    },
    "prohibitions": [
      "DB 직접 쓰기 (INSERT/UPDATE/DELETE → Orch 경유)",
      "Agent 중지/재시작",
      "Evolution 트리거 직접 실행",
      "Human 승인 없는 설정 변경"
    ]
  },

  "kpi_definitions": {
    "K-01": {
      "name": "프레임워크 채택률",
      "target": 70.0,
      "unit": "percent",
      "formula": "(사용 프로젝트 / 전체 프로젝트) × 100",
      "source": "reuse_projects",
      "collection_interval": "daily",
      "drift_alert": 60.0,
      "drift_detection": 50.0
    },
    "K-02": {
      "name": "공통 모듈 재사용률",
      "target": 50.0,
      "unit": "percent",
      "formula": "(재사용 모듈 / 전체 모듈) × 100",
      "source": "reuse_modules + reuse_usage_records",
      "collection_interval": "daily",
      "drift_alert": 40.0,
      "drift_detection": 30.0
    },
    "K-03": {
      "name": "개발 기간 단축",
      "target": 30.0,
      "unit": "percent",
      "formula": "(기존 평균 - 현재 평균) / 기존 평균 × 100",
      "source": "project started_at ~ completed_at",
      "collection_interval": "weekly",
      "drift_alert": 20.0,
      "drift_detection": 10.0
    },
    "K-04": {
      "name": "AI 승인 프로세스 단축",
      "target": 35.0,
      "unit": "percent",
      "formula": "(기존 처리시간 - 현재) / 기존 × 100",
      "source": "review_requests requested_at ~ resolved_at",
      "collection_interval": "daily",
      "drift_alert": 25.0,
      "drift_detection": 15.0
    },
    "K-05": {
      "name": "감사 준비 기간 단축",
      "target": 50.0,
      "unit": "percent",
      "formula": "(기존 기간 - 현재) / 기존 × 100",
      "source": "audit_logs report generation",
      "collection_interval": "monthly",
      "drift_alert": 40.0,
      "drift_detection": 30.0
    },
    "K-06": {
      "name": "규제 준수율",
      "target": 95.0,
      "unit": "percent",
      "formula": "governance-checker Pass / 전체 × 100",
      "source": "governance_check_results",
      "collection_interval": "daily",
      "drift_alert": 90.0,
      "drift_detection": 85.0
    },
    "K-07": {
      "name": "Drift 탐지 적용률",
      "target": 100.0,
      "unit": "percent",
      "formula": "Monitor-A 대상 KPI / 전체 KPI × 100",
      "source": "trajectory_logs DISTINCT kpi_code",
      "collection_interval": "realtime",
      "drift_alert": 90.0,
      "drift_detection": 70.0
    }
  },

  "drift_detection": {
    "levels": {
      "GREEN": { "condition": "variance ≤ 10%", "action": "로그 기록만" },
      "YELLOW": { "condition": "10% < variance ≤ 20%", "action": "Alert → PM 통보 (4h)" },
      "RED": { "condition": "variance > 20%", "action": "CRITICAL Alert → Evolution 제안 (1h)" }
    },
    "source": "governance_rules_context.json RISK-04"
  },

  "alert_system": {
    "severity_levels": {
      "INFO": { "response_time": null, "responder": null },
      "WARNING": { "response_time": "4h", "responder": "PM" },
      "CRITICAL": { "response_time": "1h", "responder": "AI Architect + PM" },
      "EMERGENCY": { "response_time": "즉시", "responder": "Governance Board + 운영팀" }
    },
    "escalation": {
      "WARNING_4h_no_response": "→ CRITICAL",
      "CRITICAL_24h_no_resolve": "→ EMERGENCY"
    }
  },

  "db_schemas": {
    "trajectory_logs": {
      "columns": [
        "id UUID PK",
        "tenant_id UUID NOT NULL",
        "kpi_code VARCHAR(10) NOT NULL",
        "kpi_name VARCHAR(100) NOT NULL",
        "target_value DECIMAL(10,2)",
        "actual_value DECIMAL(10,2)",
        "variance_pct DECIMAL(5,2)",
        "drift_level VARCHAR(10) DEFAULT 'GREEN'",
        "measured_at TIMESTAMPTZ DEFAULT NOW()",
        "measured_by VARCHAR(50) DEFAULT 'Monitor-A'",
        "created_at TIMESTAMPTZ DEFAULT NOW()",
        "created_by UUID"
      ],
      "indexes": [
        "idx_trajectory_tenant_kpi (tenant_id, kpi_code)",
        "idx_trajectory_drift (drift_level) WHERE drift_level != 'GREEN'",
        "idx_trajectory_measured (measured_at DESC)"
      ]
    },
    "kpi_alerts": {
      "columns": [
        "id UUID PK",
        "tenant_id UUID NOT NULL",
        "kpi_code VARCHAR(10)",
        "drift_level VARCHAR(10)",
        "actual_value DECIMAL(10,2)",
        "target_value DECIMAL(10,2)",
        "variance_pct DECIMAL(5,2)",
        "status VARCHAR(20) DEFAULT 'OPEN'",
        "notified_to TEXT[]",
        "notified_at TIMESTAMPTZ",
        "acknowledged_by UUID",
        "acknowledged_at TIMESTAMPTZ",
        "resolved_by UUID",
        "resolved_at TIMESTAMPTZ",
        "resolution TEXT",
        "created_at TIMESTAMPTZ DEFAULT NOW()",
        "created_by UUID"
      ]
    },
    "override_logs": {
      "columns": [
        "id UUID PK",
        "tenant_id UUID NOT NULL",
        "trigger_reason TEXT NOT NULL",
        "severity VARCHAR(20)",
        "affected_agents TEXT[]",
        "action VARCHAR(20)",
        "executed_by UUID",
        "executed_at TIMESTAMPTZ DEFAULT NOW()",
        "resolution TEXT",
        "restart_approved_by UUID",
        "restart_at TIMESTAMPTZ",
        "created_at TIMESTAMPTZ DEFAULT NOW()",
        "created_by UUID"
      ]
    }
  },

  "release_gate_g08": {
    "mandatory_conditions": [
      "RC-01: G-07 Evaluation Report 통과",
      "RC-02: Phase 4 테스트 전체 Pass (93/93)",
      "RC-03: CRITICAL 이슈 0건",
      "RC-04: Backend Docker 빌드 성공",
      "RC-05: Frontend Docker 빌드 성공",
      "RC-06: docker-compose 전체 서비스 기동",
      "RC-07: /health 200 OK",
      "RC-08: /ready 200 OK",
      "RC-09: PostgreSQL 연결 성공",
      "RC-10: Redis 연결 성공",
      "RC-11: Monitor-A 등록 완료",
      "RC-12: trajectory_logs 생성 완료",
      "RC-13: KPI 첫 수집 정상",
      "RC-14: Drift Detection 활성",
      "RC-15: Rollback 테스트 완료",
      "RC-16: .env.template 완성",
      "RC-17: Secret 하드코딩 없음"
    ],
    "recommended_conditions": [
      "RR-01: Smoke Test 7개 통과",
      "RR-02: KPI Baseline 대비 Drift 없음",
      "RR-03: Alembic 마이그레이션 정상",
      "RR-04: nginx HTTPS 설정 완료",
      "RR-05: 구조화된 JSON 로그 수집"
    ],
    "post_deploy": {
      "monitoring_period": "48h",
      "checkpoints": [
        "+1h: Health Check 연속 성공 (3회)",
        "+6h: KPI 수집 정상 (rows >= 6)",
        "+12h: Drift YELLOW/RED 없음",
        "+24h: API 응답시간 500ms 이내",
        "+48h: Post-Deploy Report 제출"
      ]
    }
  },

  "smoke_test_scenarios": [
    { "id": "ST-01", "endpoint": "GET /health", "expected": 200 },
    { "id": "ST-02", "endpoint": "GET /ready", "expected": 200 },
    { "id": "ST-03", "endpoint": "POST /api/v1/agents/invoke (auth.login)", "expected": 200 },
    { "id": "ST-04", "endpoint": "POST /api/v1/agents/invoke (menu.get_tree)", "expected": 200 },
    { "id": "ST-05", "endpoint": "POST /api/v1/agents/invoke (esignature.list)", "expected": 200 },
    { "id": "ST-06", "endpoint": "GET /api/v1/capability/skills", "expected": 200 },
    { "id": "ST-07", "endpoint": "GET /api/v1/capability/tools", "expected": 200 }
  ],

  "phase5_to_phase6_transition": {
    "conditions": [
      "G-08 Release Gate PASS",
      "프로덕션 48h 안정 운영",
      "KPI 전체 GREEN",
      "Monitor-A Drift Detection 활성",
      "Post-Deploy Report 제출"
    ],
    "next_gate": {
      "id": "G-09",
      "name": "Context 수정 승인 Gate",
      "phase": "Phase 6",
      "approver": "Governance Board",
      "hitl": "P1",
      "sla_hours": 24
    }
  }
}
