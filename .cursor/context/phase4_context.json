{
  "_meta": {
    "document": "Phase 4. Simulation Test — Cursor 컨텍스트",
    "version": "v1.0",
    "created_by": "KY Song",
    "date": "2026-03-11",
    "description": "Phase 4 시뮬레이션 테스트 시 Cursor가 참조하는 검증 기준. workflow_context.json + hitl_context.json + phase3_context.json과 함께 사용.",
    "depends_on": [
      "workflow_context.json",
      "hitl_context.json",
      "phase3_context.json",
      "saas_foundation.json"
    ]
  },

  "phase4_overview": {
    "purpose": "Phase 3에서 구현된 Agent·Module·거버넌스 코드가 설계 의도대로 동작하는지 시뮬레이션으로 검증한다",
    "lead_agents": ["Test-A", "Orch"],
    "key_gate": "G-07",
    "verification_axes": [
      { "axis": "Agent Behavior", "question": "Agent가 설계대로 실행되는가?", "sections": ["4.1"] },
      { "axis": "Governance Compliance", "question": "ApprovalGate, Scope, AuditLog가 작동하는가?", "sections": ["4.2", "4.3"] },
      { "axis": "SaaS Isolation", "question": "멀티테넌트 데이터가 격리되는가?", "sections": ["4.4"] }
    ]
  },

  "test_scenarios": {
    "4.1_agent_roleplay": {
      "description": "Agent Orchestrator 경유 원칙 준수 및 CRUD 정상 동작 검증",
      "scenarios": [
        { "id": "S-01", "name": "모듈 목록 조회", "action": "list", "expected": "success=True, items 반환" },
        { "id": "S-02", "name": "단건 생성 (승인 후)", "action": "create", "expected": "success=True, 생성된 데이터 반환" },
        { "id": "S-03", "name": "단건 조회", "action": "get", "expected": "success=True, 해당 ID 데이터" },
        { "id": "S-04", "name": "수정 (승인 후)", "action": "update", "expected": "success=True, 변경된 데이터" },
        { "id": "S-05", "name": "삭제 (soft delete, 승인 후)", "action": "delete", "expected": "success=True, deleted=True" },
        { "id": "S-06", "name": "존재하지 않는 ID 조회", "action": "get", "expected": "success=False, 에러 메시지" }
      ],
      "verification": {
        "agent_result": "모든 반환값은 AgentResult 타입",
        "trace_id": "요청-응답 trace_id 일관성",
        "execution_ms": "execution_ms >= 0 기록",
        "orchestrator_route": "모든 요청은 Orchestrator 경유"
      },
      "deliverables": ["Simulation Log (JSON)", "Conversation Log (JSON)"]
    },

    "4.2_failure_scenario": {
      "description": "의도적 실패 상황에서 프레임워크가 안전하게 실패하는지(graceful failure) 검증",
      "scenarios": [
        { "id": "F-01", "name": "DB 연결 실패", "trigger": "db=None", "expected": "AgentResult(success=False), 에러 메시지 반환" },
        { "id": "F-02", "name": "필수 파라미터 누락", "trigger": "required field missing", "expected": "AgentResult(success=False), KeyError 안전 처리" },
        { "id": "F-03", "name": "알 수 없는 액션 호출", "trigger": "unknown action", "expected": "AgentResult(success=False), '알 수 없는 액션' 메시지" },
        { "id": "F-04", "name": "Tool 3회 연속 실패", "trigger": "consecutive failures", "expected": "Orch 에스컬레이션 트리거" },
        { "id": "F-05", "name": "L0 Agent가 db_write 호출", "trigger": "scope violation", "expected": "ScopeViolationError → 차단" },
        { "id": "F-06", "name": "Orch 경유 없이 직접 Agent 호출", "trigger": "direct call", "expected": "차단" },
        { "id": "F-07", "name": "L1 Agent가 L2 권한 액션 시도", "trigger": "authority violation", "expected": "ApprovalGate 차단" }
      ],
      "verification": {
        "no_exception_leak": "모든 예외는 AgentResult로 래핑 (raise 금지)",
        "error_message": "에러 메시지에 Agent 이름 + 원인 포함",
        "escalation": "3회 연속 실패 시 Orch 에스컬레이션"
      },
      "deliverables": ["Issue List (Loop Failure)", "Issue List (Role Conflict)"]
    }
  },

  "governance_test": {
    "4.3_approval_gate": {
      "description": "ApprovalGate가 Authority Level × Risk Level 조합에 따라 정확히 동작하는지 검증",
      "test_matrix": [
        { "authority": "L0", "risk": "LOW",      "approved_by": null,    "expected": "자동 통과 (requires_approval=False)" },
        { "authority": "L0", "risk": "HIGH",     "approved_by": null,    "expected": "자동 통과 (L0는 항상 통과)" },
        { "authority": "L1", "risk": "MEDIUM",   "approved_by": null,    "expected": "차단 (requires_approval=True)" },
        { "authority": "L1", "risk": "MEDIUM",   "approved_by": "admin", "expected": "통과" },
        { "authority": "L1", "risk": "HIGH",     "approved_by": null,    "expected": "차단" },
        { "authority": "L1", "risk": "HIGH",     "approved_by": "admin", "expected": "통과" },
        { "authority": "L1", "risk": "CRITICAL", "approved_by": null,    "expected": "차단" },
        { "authority": "L1", "risk": "CRITICAL", "approved_by": "admin", "expected": "통과" }
      ],
      "rules": [
        "L0 = 항상 자동 통과 (승인 불필요)",
        "L1 이상 + approved_by 없음 = 차단",
        "HIGH/CRITICAL + approved_by 없음 = 무조건 차단",
        "approved_by 존재 시 = 통과"
      ]
    },

    "4.3_scope_validation": {
      "description": "각 Agent의 allowed_tools 범위를 넘는 Tool 호출 시 차단되는지 검증",
      "test_matrix": [
        { "agent": "ESignatureAgent", "allowed": ["db_query", "db_write"], "blocked": "api_call_external" },
        { "agent": "MenuAgent",       "allowed": ["db_query"],            "blocked": "db_write" },
        { "agent": "ApprovalsAgent",  "allowed": ["db_query", "db_write"], "blocked": "file_write" },
        { "agent": "ReuseAgent",      "allowed": ["db_query", "db_write"], "blocked": "llm_call" }
      ],
      "rules": [
        "allowed_tools 내 Tool 호출 = 통과",
        "allowed_tools 외 Tool 호출 = ScopeViolationError → 차단 + 로그",
        "Scope 위반은 workflow_context.json escalation_rules에 따라 처리"
      ]
    },

    "4.3_audit_log": {
      "description": "AuditLog가 정확히 기록되는지 검증",
      "test_items": [
        { "id": "A-01", "condition": "L1 Agent 성공", "expected_audit_logged": true },
        { "id": "A-02", "condition": "L1 Agent 실패", "expected_audit_logged": true },
        { "id": "A-03", "condition": "L0 Agent 실행", "expected_audit_logged": false },
        { "id": "A-04", "condition": "execution_ms", "expected": ">= 0" },
        { "id": "A-05", "condition": "trace_id 일치", "expected": "원본 요청과 동일" }
      ],
      "rules": [
        "L0 Agent = AuditLog 미기록 (audit_logged=False)",
        "L1 이상 Agent = 성공/실패 모두 기록 (audit_logged=True)",
        "execution_ms >= 0 항상",
        "trace_id는 원본 AgentContext.trace_id와 일치"
      ]
    }
  },

  "isolation_test": {
    "4.4_multi_tenant": {
      "description": "멀티테넌트 환경에서 데이터가 완전히 격리되는지 검증",
      "test_constants": {
        "TENANT_A": "11111111-1111-1111-1111-111111111111",
        "TENANT_B": "99999999-9999-9999-9999-999999999999",
        "USER_A": "22222222-2222-2222-2222-222222222222",
        "USER_B": "88888888-8888-8888-8888-888888888888"
      },
      "scenarios": [
        { "name": "Tenant A CRUD → Tenant B 조회 시 미노출", "expected": "items=[] 또는 None" },
        { "name": "Tenant B가 Tenant A 소유 ID 직접 조회", "expected": "None (접근 거부)" }
      ],
      "rules": [
        "모든 Repository 조회에 tenant_id 필터 필수",
        "soft delete 필터 (deleted_at IS NULL) 필수",
        "Cross-Tenant 접근 시 데이터 누출 0건"
      ]
    }
  },

  "kpi_baseline": {
    "4.5_framework_kpi": {
      "description": "project_context.json에 정의된 프레임워크 KPI의 현재 Baseline 측정",
      "kpi_items": [
        { "kpi": "공통 모듈 재사용률", "target": "50% 이상", "measurement": "(공통모듈 사용 수 / 전체 모듈 수) × 100" },
        { "kpi": "감사 대응 준비 기간", "target": "50% 단축", "measurement": "AuditLog 조회 → 보고서 생성 소요시간" },
        { "kpi": "AI 승인 프로세스", "target": "30~40% 단축", "measurement": "ApprovalGate 평균 처리시간" },
        { "kpi": "규제 준수율", "target": "95% 이상", "measurement": "governance-checker 통과율" },
        { "kpi": "Drift 자동 탐지 적용률", "target": "100%", "measurement": "Monitor-A 적용 모듈 수 (Phase 5)" }
      ]
    },
    "4.5_performance": {
      "benchmarks": [
        { "item": "Agent 평균 응답시간 (조회)", "target_ms": 500 },
        { "item": "Agent 평균 응답시간 (CUD)", "target_ms": 2000 },
        { "item": "ApprovalGate 오버헤드", "target_ms": 10 },
        { "item": "Orchestrator 라우팅 시간", "target_ms": 50 }
      ]
    }
  },

  "gate_g07": {
    "id": "G-07",
    "name": "Evaluation Report 확정 Gate",
    "hitl_pattern": "P3",
    "approver": "QA Engineer",
    "sla_hours": 48,
    "db_table": "review_requests",
    "pass_criteria": {
      "mandatory": [
        "4.1 Agent CRUD 전체 Pass",
        "4.2 Failure 시나리오 전체 안전 실패 확인",
        "4.3 ApprovalGate 매트릭스 전체 Pass",
        "4.3 AuditLog 기록률 100%",
        "4.4 멀티테넌트 격리 전체 Pass",
        "4.5 KPI Baseline 측정 완료",
        "CRITICAL 이슈 0건"
      ],
      "recommended": [
        "WARNING 이슈 조치 계획 수립"
      ]
    },
    "issue_severity": {
      "CRITICAL": "즉시 수정 필수 — Phase 5 진행 차단",
      "WARNING": "수정 권장 — Phase 5 진행 가능",
      "INFO": "참고 사항"
    }
  },

  "test_infrastructure": {
    "directory_structure": [
      "backend/tests/conftest.py                — 공통 Fixture",
      "backend/tests/modules/{module}/           — 모듈별 테스트",
      "backend/tests/modules/{module}/test_agent.py     — Agent 단위 테스트",
      "backend/tests/modules/{module}/test_service.py   — Service 단위 테스트",
      "backend/tests/modules/{module}/test_router.py    — API 통합 테스트",
      "backend/tests/modules/{module}/test_scenarios.py — E2E 시나리오",
      "backend/tests/results/                    — 테스트 결과 JSON",
      "methodology/phase4_simulation/reports/    — 검증 보고서",
      "methodology/phase4_simulation/issues/     — Issue 목록"
    ],
    "test_framework": {
      "runner": "pytest",
      "async_mode": "auto",
      "config_file": "backend/pytest.ini",
      "plugins": ["pytest-asyncio"]
    },
    "mock_strategy": {
      "db_session": "AsyncMock (SQLAlchemy AsyncSession)",
      "redis": "AsyncMock (optional)",
      "external_api": "Mock (api_call_external 차단)"
    }
  },

  "deliverables": [
    { "wbs": "4.1.1", "name": "Simulation Log", "format": "JSON", "location": "backend/tests/results/simulation_log.json" },
    { "wbs": "4.1.2", "name": "Conversation Log", "format": "JSON", "location": "backend/tests/results/conversation_log.json" },
    { "wbs": "4.2.1", "name": "Issue List (Loop)", "format": "MD", "location": "methodology/phase4_simulation/issues/" },
    { "wbs": "4.2.2", "name": "Issue List (Role)", "format": "MD", "location": "methodology/phase4_simulation/issues/" },
    { "wbs": "4.3.1", "name": "Gate Test Report", "format": "MD", "location": "methodology/phase4_simulation/reports/" },
    { "wbs": "4.3.2", "name": "Scope Violation Log", "format": "JSON", "location": "backend/tests/results/scope_violations.json" },
    { "wbs": "4.3.3", "name": "Audit Coverage Report", "format": "MD", "location": "methodology/phase4_simulation/reports/" },
    { "wbs": "4.4",   "name": "Isolation Test Report", "format": "MD", "location": "methodology/phase4_simulation/reports/" },
    { "wbs": "4.5.1", "name": "KPI Baseline Report", "format": "MD", "location": "methodology/phase4_simulation/reports/" },
    { "wbs": "4.5.2", "name": "Performance Report", "format": "MD", "location": "methodology/phase4_simulation/reports/" },
    { "wbs": "4.6.1", "name": "Evaluation Report", "format": "MD", "location": "methodology/phase4_simulation/4_6_evaluation_report.md" },
    { "wbs": "4.6.2", "name": "G-07 approval record", "format": "DB", "location": "review_requests 테이블" }
  ],

  "code_rules": {
    "cursor_instructions": [
      "테스트 파일은 backend/tests/modules/{module_name}/ 아래에 생성",
      "conftest.py에 TENANT_ID, USER_ID, OTHER_TENANT_ID 상수 정의",
      "make_context fixture로 AgentContext 생성 (팩토리 패턴)",
      "mock_db fixture로 AsyncSession Mock 제공",
      "모든 테스트 클래스: TestBasicCRUD, TestApprovalGate, TestScopeValidation, TestMultiTenantIsolation, TestAuditLog, TestErrorHandling 6개 카테고리",
      "테스트 결과는 항상 AgentResult 타입 확인 (isinstance 검사)",
      "assert 실패 시 trace_id 포함하여 디버깅 용이하게",
      "프로덕션 DB 접근 금지 — 모든 테스트는 Mock 기반"
    ]
  }
}
