{
  "_meta": {
    "document": "Phase 3. Capability 구축 — 3.2.1 Skill Library",
    "phase": "Phase 3 - Capability 구축",
    "version": "v1.0",
    "created_by": "KY Song",
    "date": "2026",
    "description": "Cursor AI가 Skill 코드 생성 시 참조하는 기준. Skill Registry 구조, Core Skill 4개 + Domain Skill 9개, 호출 규칙 정의.",
    "depends_on": [
      "system_prompt_context.json",
      "tool_context.json",
      "governance.json",
      "workflow_context.json",
      "phase3_context.json",
      "saas_foundation.json"
    ],
    "change_log": [
      { "version": "v1.0", "date": "2026", "summary": "Phase 3 Skill Library 초기 생성" }
    ]
  },

  "skill_invocation_hierarchy": {
    "description": "Skill 호출 계층 구조. Agent는 Tool을 직접 호출할 수 없다. 반드시 이 계층을 따른다.",
    "layers": [
      { "level": 1, "name": "Agent",         "role": "Skill 호출 요청",           "rule": "Tool 직접 호출 절대 금지" },
      { "level": 2, "name": "Skill Registry", "role": "Skill 등록·검증·라우팅",    "rule": "허용 Agent 검증 후 Skill 실행" },
      { "level": 3, "name": "Skill",          "role": "비즈니스 로직 캡슐화",      "rule": "Tool Registry 경유로만 Tool 호출" },
      { "level": 4, "name": "Tool Registry",  "role": "Tool 등록·권한 검증·실행", "rule": "allowed_agents 검증 후 Tool 실행" },
      { "level": 5, "name": "Tool",           "role": "실제 실행 (DB/API/LLM 등)", "rule": "Tool 직접 호출 금지. Tool Registry 경유만 허용" }
    ],
    "invocation_flow": [
      "① Agent.execute() → ② skill_registry.invoke(skill_name, agent_code) → ③ Skill.run() → ④ tool_registry.call(tool_name) → ⑤ Tool 실행",
      "역방향 호출 절대 금지 (예: Tool에서 Skill 호출 금지)"
    ],
    "cursor_code_rule": "Agent 코드에서 Tool 직접 import 및 호출 금지. 반드시 skill_registry.invoke() 경유"
  },

  "skill_registry": {
    "description": "Skill Registry 구조 및 DB 스키마 정의. 런타임 Skill 동적 등록 지원.",
    "db_table": "skill_registry",
    "columns": [
      { "name": "id",               "type": "UUID",      "desc": "Skill 고유 ID" },
      { "name": "skill_name",       "type": "VARCHAR",   "desc": "Skill 식별자 (예: back.generate_db_migration)" },
      { "name": "skill_version",    "type": "VARCHAR",   "desc": "Skill 버전 (예: v1.0)" },
      { "name": "description",      "type": "TEXT",      "desc": "Skill 목적 설명" },
      { "name": "allowed_agents",   "type": "JSON",      "desc": "이 Skill을 사용할 수 있는 Agent 코드 목록" },
      { "name": "requires_approval","type": "BOOLEAN",   "desc": "Human 승인 필요 여부 (P1 게이트)" },
      { "name": "risk_level",       "type": "VARCHAR",   "desc": "Skill 실행 Risk Level (LOW/MEDIUM/HIGH/CRITICAL)" },
      { "name": "tool_dependencies","type": "JSON",      "desc": "이 Skill이 의존하는 Tool 이름 목록" },
      { "name": "is_active",        "type": "BOOLEAN",   "desc": "활성화 여부" },
      { "name": "created_at",       "type": "TIMESTAMPTZ","desc": "등록 시각" }
    ],
    "rules": [
      "skill_name은 {agent_prefix}.{action_name} 형식 필수 (예: back.generate_db_migration)",
      "allowed_agents에 없는 Agent의 호출 즉시 차단",
      "requires_approval=true인 Skill: P1 approval_requests INSERT 후 APPROVED 상태 확인 필수",
      "Skill 추가/수정: Governance Board 승인 후 is_active=true 설정",
      "is_active=false Skill 호출 시 SkillDisabledException 발생"
    ]
  },

