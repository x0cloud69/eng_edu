## 규칙 5 — SLA 타임아웃 처리 필수

```python
# ✅ SLA 초과 시 자동 처리 포함
try:
    approved = await wait_for_approval(approval_id, timeout_hours=24)
except ApprovalTimeoutException:
    # P1 24h 초과 → 자동 취소 + Escalation
    await audit_log(ctx, "P1_SLA_EXCEEDED")
    await escalate_to_human(override_id, sla_hours=2, notify_roles=["pm"])
    raise

try:
    decision = await wait_for_override_decision(override_id, timeout_hours=2)
except EscalationTimeoutException:
    # P2 2h 초과 → 자동 실행 중단 (안전 원칙 우선)
    await audit_log(ctx, "P2_SLA_EXCEEDED_AUTO_STOP")
    raise HumanStoppedException(override_id=override_id)

# ❌ 금지
approved = await wait_for_approval(approval_id, timeout_hours=24)
# 타임아웃 예외 처리 없음 — 금지
```

