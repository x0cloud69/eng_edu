## 규칙 2 — P2: 위험 감지 패턴 (On-Risk Override)

**적용 대상**: KPI 20% 이상 하락, CRITICAL Risk 감지, 반복 실패 3회 이상

```python
# ✅ P2 패턴 표준 코드 — Risk 감지 즉시 Human에 전달
from backend.src.core.hitl import create_override_request, escalate_to_human

async def handle_risk_event(self, ctx: AgentContext, risk_event: dict, db):
    # Step 1: override_logs INSERT (즉시 — SLA 2h)
    override_id = await create_override_request(
        db=db,
        org_id=ctx.org_id,
        agent_code=self.name,
        trigger_type=risk_event["type"],   # DRIFT_DETECTED / REPEATED_FAILURE 등
        risk_level=risk_event["level"],
        description=risk_event["description"],
        trace_id=ctx.trace_id
    )

    # Step 2: 즉시 알림 발송 (SLA 2h 카운트다운 시작)
    await escalate_to_human(
        override_id=override_id,
        sla_hours=2,
        notify_roles=["architect", "pm"]
    )

    # Step 3: Human 판단 대기 — 이 시점에서 Agent 실행 일시 정지
    decision = await wait_for_override_decision(override_id, timeout_hours=2)

    if decision == "STOP":
        await audit_log(ctx, "P2_HUMAN_STOPPED")
        raise HumanStoppedException(override_id=override_id)
    elif decision == "CONTINUE":
        await audit_log(ctx, "P2_HUMAN_CONTINUED")
        # 계속 진행
    elif decision == "TIMEOUT":
        # 2h SLA 초과 시 자동 실행 중단
        raise EscalationTimeoutException(override_id=override_id)

# ✅ Monitor-A에서 Drift 감지 시 P2 자동 트리거
async def detect_and_escalate(self, ctx, kpi_drop_percent: float):
    if kpi_drop_percent >= 20:
        await self.handle_risk_event(ctx, {
            "type": "DRIFT_DETECTED",
            "level": "HIGH",
            "description": f"KPI {kpi_drop_percent:.1f}% 하락 감지"
        }, db=None)

# ❌ 금지
if kpi_drop_percent >= 20:
    pass  # P2 트리거 없이 무시 금지
```

**Frontend P2 알림 UI:**
```tsx
// ✅ P2 위험 감지 시 RiskBanner + 즉시 처리 버튼
{riskEvent && (
  <RiskBanner
    riskLevel="HIGH"
    traceId={traceId}
    message={riskEvent.description}
    actions={[
      <Button key="stop" variant="destructive" onClick={handleStop}>실행 중단</Button>,
      <Button key="cont" variant="secondary" onClick={handleContinue}>계속 진행</Button>
    ]}
  />
)}
```

