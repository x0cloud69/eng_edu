## 규칙 1 — P1: 사전 승인 패턴 (Pre-Approval)

**적용 대상**: DB 스키마 변경(G-06), 외부 API 호출, 배포 트리거, Semantic Memory 등록

```python
# ✅ P1 패턴 표준 코드
from backend.src.core.hitl import create_approval_request, wait_for_approval
from backend.src.core.exceptions import ApprovalRejectedException, ApprovalTimeoutException

async def execute_with_p1_gate(self, ctx: AgentContext, db) -> AgentResult:
    # Step 1: approval_requests INSERT
    approval_id = await create_approval_request(
        db=db,
        org_id=ctx.org_id,
        agent_code=self.name,
        action=ctx.action,
        gate_id="G-06",           # workflow_context.json gates 기준
        payload_summary=mask_pii(str(ctx.payload)),
        risk_level="HIGH",
        trace_id=ctx.trace_id,
        requested_by=ctx.user_id
    )

    # Step 2: APPROVED 상태 대기 (SLA 24h)
    approved = await wait_for_approval(
        approval_id=approval_id,
        timeout_hours=24
    )

    if not approved:
        await audit_log(ctx, "P1_APPROVAL_REJECTED", {"approval_id": str(approval_id)})
        raise ApprovalRejectedException(gate_id="G-06", approval_id=approval_id)

    # Step 3: 승인 후 실행
    result = await self._do_execute(ctx, db)
    await audit_log(ctx, "P1_APPROVED_EXECUTED", {"approval_id": str(approval_id)})
    return result

# ❌ 절대 금지
async def execute(self, ctx, db):
    # P1 없이 DB 변경 — 금지
    await tool_registry.call("db_write", ...)
```

