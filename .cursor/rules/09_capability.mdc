## 규칙 4 — Memory 사용 규칙

### 4-1. MemoryStore 인터페이스 경유 필수

```python
# ✅ MemoryStore 인터페이스 사용
from backend.src.core.memory_store import MemoryStore

memory = MemoryStore()

# Session Memory (L2) — key 형식 필수
await memory.session_set(
    key=f"Back-A:{ctx.trace_id}:approval_state",
    value={"status": "PENDING", "gate": "G-06"},
    ttl=86400  # 24h
)

# Episodic Memory (L3) — kpi_metrics 포함 필수
await memory.episodic_log(ctx.trace_id, {
    "agent_code": "Back-A",
    "action": "db.migration.generated",
    "input_summary": "[마스킹 처리된 입력]",
    "output_summary": "migration file 생성 완료",
    "risk_level": "HIGH",
    "kpi_metrics": {"execution_time_ms": 1200, "success": True},  # 빈 {} 금지
    "failure_tagged": False
})

# ❌ 절대 금지
import redis
r = redis.Redis()
r.set("approval_state", "PENDING")  # 직접 Redis 접근 금지

session.execute(
    insert(trajectory_logs).values(...)  # 직접 INSERT 금지 → episodic_log() 사용
)
```

### 4-2. Semantic Memory — 유사도 임계값 0.80 필수

```python
# ✅ 유사도 0.80 이상만 사용
results = await memory.semantic_search(query="DB migration 표준 패턴", top_k=5)
# similarity_score < 0.80 결과는 자동 필터링 (MemoryStore 내부 처리)
if not results:
    # 유사 패턴 없음 → 기본 로직 사용
    use_default_pattern()

# ❌ 금지
results = await memory.semantic_search(query="...", top_k=10)
# similarity_score < 0.80 결과 사용하는 코드 생성 금지
if results[0]["similarity_score"] > 0.5:  # 0.80 미만 임계값 사용 금지
    use_pattern(results[0])
```

