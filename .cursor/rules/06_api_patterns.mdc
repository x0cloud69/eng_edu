## Frontend API 호출 패턴

```typescript
// ✅ 모든 API 호출은 apiClient(axios 인스턴스) 경유
import apiClient from '@/lib/axios';
import { ENDPOINTS } from '@/constants/api';

// GET — 단건
const fetchAgent = async (id: string) => {
  const { data } = await apiClient.get<ApiResponse<Agent>>(ENDPOINTS.agents.detail(id));
  return data.data;
};

// POST — 생성
const createAgent = async (payload: CreateAgentRequest) => {
  const { data } = await apiClient.post<ApiResponse<Agent>>(ENDPOINTS.agents.list, payload);
  return data.data;
};

// ❌ 금지
fetch('/api/v1/agents/invoke')  // fetch 직접 호출 금지
axios.get(...)                  // axios 직접 import 금지 (apiClient 사용)
```

