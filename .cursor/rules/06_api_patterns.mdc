## SSE (Server-Sent Events) 스트리밍 패턴

```python
# ✅ SSE 이벤트 형식
@router.post("/{agent_id}/run/stream")
async def stream_agent(agent_id: UUID, ...):
    async def event_generator():
        async for event in agent_service.stream(agent_id, ...):
            if event["type"] == "token":
                yield f"data: {json.dumps(event)}\n\n"
            elif event["type"] == "done":
                yield f"data: {json.dumps(event)}\n\n"
                break
            elif event["type"] == "error":
                yield f"data: {json.dumps(event)}\n\n"
                break

    return StreamingResponse(
        event_generator(),
        media_type="text/event-stream",
        headers={
            "Cache-Control": "no-cache",
            "X-Accel-Buffering": "no",   # nginx 버퍼링 비활성화 필수
        }
    )

# SSE 이벤트 타입
# token      — LLM 스트리밍 텍스트 조각
# tool_start — Tool 호출 시작
# tool_end   — Tool 호출 완료
# done       — 전체 실행 완료
# error      — 오류 발생
```

