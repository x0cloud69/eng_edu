## Mutation 패턴 (React Query)

```typescript
// ✅ Optimistic Update 패턴
const mutation = useMutation({
  mutationFn: (payload: UpdateAgentRequest) =>
    apiClient.patch(ENDPOINTS.agents.detail(agentId), payload),
  onMutate: async (newData) => {
    await queryClient.cancelQueries({ queryKey: ['agents', agentId] });
    const previous = queryClient.getQueryData(['agents', agentId]);
    queryClient.setQueryData(['agents', agentId], newData);  // 낙관적 업데이트
    return { previous };
  },
  onError: (err, _, context) => {
    queryClient.setQueryData(['agents', agentId], context?.previous);  // 롤백
  },
  onSettled: () => {
    queryClient.invalidateQueries({ queryKey: ['agents', agentId] });  // 재동기화
  },
});
```

