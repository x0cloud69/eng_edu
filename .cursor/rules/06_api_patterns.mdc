## 페이지네이션 연동 패턴

```typescript
// ✅ usePagination 훅 + React Query 연동
const { page, size, setPage } = usePagination();

const { data } = useQuery({
  queryKey: ['agents', { page, size, status: filterStatus }],
  queryFn: () => apiClient.get(ENDPOINTS.agents.list, {
    params: { page, size, status: filterStatus }
  }).then(r => r.data.data),
  placeholderData: keepPreviousData,  // 페이지 전환 시 이전 데이터 유지
});
```

