## Backend 코드 패턴

```python
# ✅ 라우터 — 서비스 호출만, 비즈니스 로직 없음
@router.get("/{agent_id}", response_model=ApiResponse[AgentSchema])
async def get_agent(
    agent_id: UUID,
    ctx: TenantContext = Depends(get_tenant_context),
    db: AsyncSession = Depends(get_db),
):
    agent = await agent_service.get_by_id(agent_id, ctx.org_id, db)
    return ApiResponse(data=AgentSchema.model_validate(agent))

# ✅ 서비스 — 비즈니스 로직, DB 직접 접근 없음
class AgentService:
    async def get_by_id(self, agent_id: UUID, org_id: UUID, db) -> Agent:
        agent = await self.repo.get(agent_id, org_id, db)
        if not agent:
            raise NotFoundException("Agent")
        return agent

# ✅ Repository — DB CRUD만, 비즈니스 로직 없음
class AgentRepository:
    async def get(self, agent_id: UUID, org_id: UUID, db) -> Agent | None:
        result = await db.execute(
            select(Agent)
            .where(Agent.id == agent_id)
            .where(Agent.organization_id == org_id)  # 테넌트 필터 필수
            .where(Agent.deleted_at.is_(None))        # Soft Delete 필터 필수
        )
        return result.scalar_one_or_none()
```

**레이어 규칙:**
```
Router  → Service 호출만 (DB/모델 직접 접근 금지)
Service → Repository 호출만 (직접 SQL 금지)
Repository → DB 쿼리만 (비즈니스 로직 금지)
```

