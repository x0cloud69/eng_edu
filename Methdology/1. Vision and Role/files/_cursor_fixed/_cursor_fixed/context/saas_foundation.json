{
  "_meta": {
    "document": "Phase 0. SaaS Foundation 정의",
    "version": "v1.0",
    "created_by": "KY Song",
    "date": "2026",
    "description": "모든 SaaS 프로젝트 공통 재활용 기반. Phase 3 구현의 직접 기준. 7개 영역 74개 Task 통합.",
    "infra": "Cloud (AWS / GCP / Azure)",
    "tech_stack": { "backend": "Python + FastAPI", "frontend": "TypeScript + React", "db": "PostgreSQL", "cache": "Redis", "storage": "S3 호환" }
  },

  "architecture": {
    "multitenancy": {
      "strategy": "Row Level (tenant_id 컬럼)",
      "rule": "모든 테이블에 tenant_id UUID 컬럼 필수. RLS(Row Level Security) 적용 권장.",
      "alternatives": ["DB per Tenant (Enterprise)", "Schema per Tenant (중규모)"]
    },
    "i18n": {
      "storage": "DB i18n_messages 테이블 + 빌드 시 JSON 추출",
      "fallback": "ko → en → key 그대로",
      "library": "i18next",
      "dynamic": "관리자 UI에서 언어 추가 가능",
      "date_format": "date-fns locale / Intl API"
    },
    "decisions": [
      { "item": "서비스 구조",   "decision": "Modular Monolith",          "reason": "초기 속도 + 향후 분리 용이" },
      { "item": "통신 방식",     "decision": "REST(동기) + Queue(비동기)", "reason": "Agent 간 비동기 필요" },
      { "item": "캐싱",         "decision": "Redis",                      "reason": "세션·공통코드·메뉴·LLM 응답" },
      { "item": "파일 스토리지", "decision": "S3 호환",                   "reason": "클라우드 추상화" },
      { "item": "API 버전",      "decision": "/api/v1/ URL Path",         "reason": "하위 호환 보장" }
    ]
  },

  "common_modules": {
    "auth": {
      "access_token_ttl": "15분",
      "refresh_token_ttl": "30일",
      "hash": "bcrypt cost=12",
      "oauth_providers": ["Google", "Kakao", "기타 소셜"],
      "oauth_pattern": "Provider별 어댑터 패턴으로 추상화",
      "sso": "SAML 2.0 / OIDC (Enterprise)",
      "rbac": "Role → Permission → Resource 3단계",
      "soft_delete": "is_active=false (물리 삭제 금지)"
    },
    "menu": {
      "structure": "adjacency list (parent_id)",
      "cache": "Redis (변경 시 자동 갱신)",
      "scope": "Tenant별 독립 메뉴"
    },
    "program": {
      "unique": "program_code (tenant 범위)",
      "numbering": "채번 규칙 테이블 + SELECT FOR UPDATE 동시성 제어",
      "format": "prefix + format + seq (예: ORD-2026-00001)"
    },
    "common_code": {
      "structure": "code_group + code_item + i18n_key",
      "cache": "Redis (변경 시 자동 갱신)"
    },
    "utils": {
      "categories": ["날짜", "문자", "숫자", "유효성 검사", "포맷 변환"],
      "rule": "utils/ 패키지 — 테스트 100% 커버리지 필수"
    },
    "notification": {
      "channels": ["인앱", "이메일", "SMS"],
      "pattern": "Provider 어댑터 (SendGrid / AWS SES / Twilio)",
      "delivery": "비동기 Queue (SQS / Celery) + 실패 재시도"
    },
    "file": {
      "storage": "S3 Presigned URL",
      "constraints": "파일 타입·크기 제한 + Tenant별 용량 제한",
      "security": "바이러스 검사 (업로드 시)"
    },
    "billing": {
      "providers": ["Stripe", "토스페이먼츠"],
      "pattern": "어댑터 패턴 + 웹훅 이벤트 기반",
      "tables": ["subscriptions", "billing_history", "plans"]
    },
    "dashboard": {
      "features": ["위젯 시스템", "차트", "데이터 집계", "CSV/Excel 내보내기"],
      "cache": "집계 쿼리 캐싱"
    },
    "batch": {
      "tool": "Celery Beat / APScheduler",
      "monitoring": "Dead Letter Queue + 실패 알림"
    },
    "api_response": {
      "success": "{ success: true, data: any, meta: { page, total, size } }",
      "error":   "{ success: false, error: { code, message, detail } }",
      "pagination": "page / size / total / items"
    }
  },

  "llm_commons": {
    "provider_abstraction": {
      "interface": "LLMProvider",
      "methods": ["complete(prompt, model, options)", "embed(text, model)", "vision(image, prompt)", "stream(prompt)"],
      "providers": ["OpenAI", "Claude (Anthropic)", "Gemini (Google)", "자체 모델"],
      "rule": "Provider 교체 시 어댑터만 교체. Agent 코드 변경 없음."
    },
    "prompt_management": {
      "storage": "DB prompt_templates 테이블",
      "versioning": "prompt_version 컬럼 + 기본 버전 설정",
      "i18n": "locale별 Prompt 분리 (prompt_i18n 테이블)",
      "template_engine": "jinja2 ({{variable}} 치환)",
      "admin_ui": "관리자가 UI에서 편집 가능"
    },
    "base_agent": {
      "signature": "AgentContext → AgentResult",
      "rule": "모든 Agent는 BaseAgent 상속 필수",
      "context_load": "실행 전 Global Context 반드시 로드 (load_global_context())"
    },
    "tool_registry": {
      "storage": "tool_registry 테이블",
      "fields": ["tool_name", "version", "description", "allowed_agents", "requires_approval"],
      "loading": "동적 로드 — 런타임 Tool 추가 가능"
    },
    "memory_store": {
      "short_term": "Redis (TTL Agent별 설정)",
      "long_term": "PostgreSQL (agent_memory 테이블)",
      "abstraction": "MemoryStore 인터페이스 — Agent 코드에서 직접 Redis/DB 접근 금지"
    },
    "cost_tracking": {
      "table": "llm_call_logs",
      "fields": ["model", "prompt_tokens", "completion_tokens", "cost_usd", "tenant_id"],
      "budget_limit": "Tenant별 월간 예산 제한 설정 가능"
    },
    "response_cache": {
      "key": "hash(prompt + model)",
      "storage": "Redis",
      "ttl": "Agent별 설정 (기본 1시간)"
    },
    "injection_defense": {
      "middleware": "Input Sanitizer 공통 미들웨어",
      "pattern": "패턴 필터링 + 길이 제한 + 특수 명령어 차단"
    }
  },

  "security": {
    "zero_trust": {
      "principles": [
        "Never Trust, Always Verify — JWT 검증 미들웨어 모든 엔드포인트",
        "최소 권한 — RBAC Permission 세분화",
        "명시적 접근 허용 — Whitelist 기반",
        "지속적 검증 — Redis 토큰 검증 + 만료 갱신",
        "마이크로 세그멘테이션 — 내부 API도 Bearer Token"
      ]
    },
    "rate_limiting": {
      "api_per_minute": 100,
      "user_per_minute": 60,
      "tool": "FastAPI slowapi + Redis"
    },
    "cors": { "policy": "Whitelist 도메인만 허용", "tool": "FastAPI CORSMiddleware" },
    "web_security": {
      "sql_injection": "SQLAlchemy ORM 전용 + 파라미터 바인딩",
      "xss": "DOMPurify(Frontend) + CSP Header",
      "csrf": "SameSite Cookie + CSRF Token"
    },
    "session": {
      "access_token": "15분", "refresh_token": "7일",
      "concurrent_login": "Tenant 정책별 설정",
      "storage": "Redis Blacklist"
    },
    "pii_masking": {
      "rule": "로그 출력 시 자동 마스킹 (이름·전화·이메일)",
      "tool": "Loguru filter + 정규식 패턴"
    }
  },

  "design_system": {
    "base": "Tailwind CSS + shadcn/ui",
    "tokens": {
      "color": "--color-primary / --color-secondary (CSS 변수)",
      "typography": "제목 24px · 본문 14px · 캡션 12px (Inter 폰트)",
      "spacing": "4px 단위 (Tailwind p-1 = 4px)",
      "border_radius": "sm:4px / md:8px / lg:16px / full:9999px",
      "shadow": "sm / md / lg 3단계",
      "breakpoints": "sm:640 / md:768 / lg:1024 / xl:1280"
    },
    "components": [
      "Button (Primary·Secondary·Destructive·Ghost·Loading)",
      "Input / Form (react-hook-form + zod)",
      "Table / DataGrid (TanStack Table v8)",
      "Modal / Dialog (shadcn/ui Dialog)",
      "Toast / Alert (4종)",
      "Skeleton (로딩 상태)",
      "Empty State (데이터 없음·에러)",
      "ApprovalGate UI (HITL 연계)",
      "Chart / 대시보드 (Recharts)",
      "다크모드 (class-based)"
    ],
    "accessibility": "WCAG 2.1 AA",
    "dark_mode": "시스템 설정 자동 감지 + 수동 전환"
  },

  "db_schema": {
    "common_columns": {
      "id": "UUID PRIMARY KEY DEFAULT gen_random_uuid()",
      "tenant_id": "UUID FK → tenants.id (멀티테넌트 테이블 전체)",
      "created_at": "TIMESTAMPTZ DEFAULT NOW()",
      "updated_at": "TIMESTAMPTZ (트리거 자동 갱신)",
      "created_by": "UUID FK → users.id",
      "is_active": "BOOLEAN DEFAULT TRUE",
      "is_deleted": "BOOLEAN DEFAULT FALSE"
    },
    "tables": [
      { "name": "tenants",           "purpose": "Tenant 마스터",        "key_columns": ["id","name","plan","status","settings(JSON)"] },
      { "name": "users",             "purpose": "사용자 마스터",         "key_columns": ["id","tenant_id","email","name","is_active","last_login"] },
      { "name": "roles",             "purpose": "역할 정의",            "key_columns": ["id","tenant_id","name","description"] },
      { "name": "permissions",       "purpose": "권한 항목",            "key_columns": ["id","resource","action","description"] },
      { "name": "menus",             "purpose": "메뉴 트리",            "key_columns": ["id","tenant_id","parent_id","name","url","icon","sort_order","role_ids"] },
      { "name": "programs",          "purpose": "프로그램 마스터",       "key_columns": ["id","tenant_id","program_code","name","is_active"] },
      { "name": "program_numbers",   "purpose": "채번 규칙",            "key_columns": ["id","program_id","prefix","format","seq","reset_cycle"] },
      { "name": "common_codes",      "purpose": "공통코드",              "key_columns": ["id","tenant_id","group_code","code","name","sort_order","i18n_key"] },
      { "name": "i18n_messages",     "purpose": "다국어 번역",           "key_columns": ["id","key","locale","value","updated_at"] },
      { "name": "audit_logs",        "purpose": "감사 로그",             "key_columns": ["id","tenant_id","user_id","action","resource","payload","created_at"] },
      { "name": "llm_call_logs",     "purpose": "LLM 호출 이력",        "key_columns": ["id","tenant_id","agent_code","model","prompt_tokens","completion_tokens","cost_usd"] },
      { "name": "prompt_templates",  "purpose": "Prompt 템플릿",        "key_columns": ["id","tenant_id","name","content","version","locale","is_active"] }
    ],
    "rules": [
      "모든 테이블 물리 삭제 금지 — is_active=false 또는 is_deleted=true",
      "audit_logs DELETE/UPDATE 쿼리 절대 금지",
      "tenant_id 없는 멀티테넌트 테이블 배포 차단",
      "Alembic 마이그레이션 — 배포 전 자동 실행"
    ]
  },

  "infra": {
    "containerization": {
      "strategy": "멀티스테이지 빌드 (base → deps → builder → runtime)",
      "local_dev": "docker-compose.dev.yml (DB·Redis·앱 통합)"
    },
    "ci_cd": {
      "tool": "GitHub Actions (기본) / GitLab CI (대안)",
      "ci_steps": ["lint", "type-check", "test", "build", "security-scan"],
      "cd_steps": ["build-image", "push-ECR", "deploy-ECS/K8s"],
      "trigger": { "ci": "PR 시 자동", "cd": "main 브랜치 머지 시 자동" }
    },
    "environments": ["dev", "staging", "prod"],
    "secret_management": "AWS Secrets Manager / GCP Secret Manager (환경변수 직접 노출 금지)",
    "deployment_strategy": {
      "blue_green": "ALB Target Group 전환",
      "canary": "5% → 25% → 100% 단계적",
      "rollback": "이전 이미지 태그로 즉시 (< 5분)"
    },
    "health_check": {
      "liveness": "GET /health",
      "readiness": "GET /ready (DB 연결 확인)"
    },
    "db_migration": "Alembic (alembic upgrade head — CI 통합)",
    "iac": "Terraform / AWS CDK (infra/ 디렉토리 — 버전 관리 필수)",
    "branch_strategy": "GitFlow (main/develop/feature*/hotfix*)"
  },

  "code_rules": {
    "cursor_instructions": [
      "멀티테넌트: 모든 DB 쿼리에 tenant_id 필터 자동 포함",
      "인증: 모든 API 엔드포인트에 JWT 검증 미들웨어 적용",
      "공통 응답: { success, data, error, meta } 형식 필수",
      "물리 삭제 금지: DELETE 쿼리 대신 is_active=false",
      "audit_logs: 상태 변경 시 항상 INSERT",
      "LLM 호출: LLMProvider 추상화 인터페이스 사용 (직접 SDK 호출 금지)",
      "BaseAgent: 모든 Agent 클래스는 BaseAgent 상속 필수",
      "Tool 호출: tool_registry 테이블에 등록된 Tool만 사용",
      "i18n: 하드코딩 문자열 금지 — i18n_messages 참조",
      "환경변수: 코드 내 Secret 하드코딩 절대 금지"
    ]
  }
}
