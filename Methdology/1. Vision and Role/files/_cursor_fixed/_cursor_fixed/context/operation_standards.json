  "five_principles": {
    "description": "AI 운영 5대 원칙 — 모든 표준의 상위 기준 (0_C)",
    "principles": [
      {
        "id": 1,
        "name": "전략과 실행의 분리",
        "en": "Separation of Strategy & Execution",
        "rules": [
          "Global Context와 Agent 실행 코드는 반드시 분리",
          "Agent는 Context를 해석하지 않으며 구조화된 제약만 따름",
          "Context 변경은 Governance 승인 후 반영"
        ],
        "code_rule": "Agent 함수 안에 전략 판단 로직 직접 작성 금지"
      },
      {
        "id": 2,
        "name": "최소 권한 원칙",
        "en": "Least Privilege Principle",
        "rules": [
          "모든 Agent는 필요한 최소 범위 내에서만 권한 보유",
          "Scope 초과 실행 금지",
          "권한 상승은 공식 승인 절차를 통해서만 가능"
        ],
        "code_rule": "각 Agent는 allowed_tools, allowed_scope만 실행"
      },
      {
        "id": 3,
        "name": "감사 가능성 우선",
        "en": "Auditability by Design",
        "rules": [
          "모든 의사결정은 추적 가능해야 함",
          "승인, 실행, 변경 이력은 로그로 기록",
          "책임(Accountability)은 항상 인간 조직에 귀속"
        ],
        "code_rule": "모든 Agent 실행 → audit_logs INSERT 필수, 로그 없는 상태 변경 금지"
      },
      {
        "id": 4,
        "name": "리스크 기반 통제",
        "en": "Risk-Based Control",
        "rules": [
          "자율성 수준은 리스크 등급에 비례하여 결정",
          "HIGH 이상 리스크는 강화된 통제 및 Human 승인 적용",
          "Drift 및 KPI 이상 징후 감지 시 즉시 재평가"
        ],
        "code_rule": "Risk Level 체크 로직 모든 Agent 필수 포함"
      },
      {
        "id": 5,
        "name": "지속적 개선 체계 내재화",
        "en": "Built-in Evolution Loop",
        "rules": [
          "KPI 및 모니터링 결과는 반드시 개선 활동으로 연결",
          "Context 수정은 승인 및 회귀 테스트 후 반영",
          "반복되는 예외는 구조적 개선 대상으로 전환"
        ],
        "code_rule": "trajectory_logs 테이블에 실행 궤적 기록 필수"
      }
    ]
  },

  "context_management": {
    "description": "AI Context 관리 표준 (0_2)",
    "layers": [
      {
        "level": 1,
        "name": "Global Strategic Context",
        "file": ".cursor/context/project_context.json",
        "contains": ["Scope", "Authority", "KPI", "Risk", "Governance"],
        "rule": "모든 Agent 실행 전 반드시 로드, 변경 시 Governance 승인 필수"
      },
      {
        "level": 2,
        "name": "Agent-Specific Context",
        "file": ".cursor/context/agents/{agent_name}_context.json",
        "contains": ["allowed_scope", "allowed_tools", "allowed_skills", "execution_constraints"],
        "rule": "Global Context로부터 자동 생성, 직접 수정 금지"
      },
      {
        "level": 3,
        "name": "Runtime Context",
        "file": "DB 또는 메모리 (세션 단위)",
        "contains": ["user_input", "session_state", "dynamic_variables"],
        "rule": "Global/Agent Context 변경 불가"
      }
    ],
    "change_procedure": [
      "KPI 또는 Risk 변화 감지",
      "Risk 재평가 수행",
      "Global Context 수정 제안 작성",
      "Governance Board 승인",
      "Agent Context 자동 재생성",
      "Regression Test 수행",
      "승인 후 재배포"
    ]
  },

